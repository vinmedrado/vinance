APP_NAME=FinanceOS
FINANCEOS_ENV=production
FINANCEOS_DEV_MODE=false
APP_VERSION=1.0.0
DEMO_MODE_ENABLED=true
ANALYTICS_ENABLED=true

SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://financeos:${POSTGRES_PASSWORD}@postgres:5432/financeos
SYNC_DATABASE_URL=postgresql+psycopg2://financeos:${POSTGRES_PASSWORD}@postgres:5432/financeos
POSTGRES_DB=financeos
POSTGRES_USER=financeos
POSTGRES_PASSWORD=replace-me
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60

SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0.05
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
BILLING_SUCCESS_URL=https://your-domain.com/planos?billing=success
BILLING_CANCEL_URL=https://your-domain.com/planos?billing=cancel
BILLING_PORTAL_RETURN_URL=https://your-domain.com/planos

VITE_API_URL=/api
VITE_ANALYTICS_ENABLED=true
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
