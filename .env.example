APP_NAME=FinanceOS
FINANCEOS_ENV=development
FINANCEOS_DEV_MODE=true
APP_VERSION=1.0.0
DEMO_MODE_ENABLED=true
ANALYTICS_ENABLED=false

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://financeos:financeos@postgres:5432/financeos
SYNC_DATABASE_URL=postgresql+psycopg2://financeos:financeos@postgres:5432/financeos
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
MLFLOW_TRACKING_URI=http://mlflow:5000

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60

SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0.05
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
BILLING_SUCCESS_URL=http://localhost:3000/planos?billing=success
BILLING_CANCEL_URL=http://localhost:3000/planos?billing=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/planos

DEFAULT_LANGUAGE=pt_BR
DEFAULT_CURRENCY=BRL
SENDGRID_API_KEY=

VITE_API_URL=/api
VITE_ANALYTICS_ENABLED=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
